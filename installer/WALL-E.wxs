<?xml version="1.0" encoding="UTF-8"?>

<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">

  <Product Id="*"

           Name="WALL-E 桌面宠物"

           Language="2052"

           Version="1.1.0.0"

           Manufacturer="WALL-E"

           UpgradeCode="8B2E4F1A-9C3D-4E5F-A6B7-1D2E3F4A5B6C">

    <Package InstallerVersion="500"

             Compressed="yes"

             InstallScope="perUser"

             Description="WALL-E 桌面宠物（支持中英文界面）"

             Comments="WALL-E Desktop Pet · 待办 / 番茄钟 / 提醒" />

    <MajorUpgrade DowngradeErrorMessage="已安装更高版本，无法降级安装。" />

    <MediaTemplate EmbedCab="yes" />



    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLDIR" />

    <UIRef Id="WixUI_Minimal" />



    <Icon Id="WalleIcon.ico" SourceFile="..\assets\walle.ico" />

    <Property Id="ARPPRODUCTICON" Value="WalleIcon.ico" />



    <Directory Id="TARGETDIR" Name="SourceDir">

      <Directory Id="LocalAppDataFolder">

        <Directory Id="INSTALLDIR" Name="Programs\WALL-E">

          <Component Id="MainExecutable" Guid="7A1D3E2B-8F4C-4D5E-9A6B-0C1D2E3F4A5B">

            <File Id="WalleExe"

                  Source="..\dist\WALL-E.exe"

                  KeyPath="yes"

                  Checksum="yes" />

            <File Id="UserManual"

                  Source="..\操作手册.md"

                  Name="操作手册.md" />

            <File Id="UserGuideEn"

                  Source="..\USER_GUIDE.md"

                  Name="USER_GUIDE.md" />

          </Component>

        </Directory>

      </Directory>

      <Directory Id="DesktopFolder" Name="Desktop">

        <Component Id="DesktopShortcut" Guid="6B0C2D1A-7E3B-4C4D-8A5B-9F0E1D2C3B4A">

          <Shortcut Id="DesktopShortcut"

                    Name="WALL-E Assistant"

                    Target="[INSTALLDIR]WALL-E.exe"

                    WorkingDirectory="INSTALLDIR"

                    Icon="WalleIcon.ico"

                    Description="WALL-E Assistant" />

          <RegistryValue Root="HKCU"

                         Key="Software\WALL-E"

                         Name="DesktopShortcut"

                         Type="integer"

                         Value="1"

                         KeyPath="yes" />

        </Component>

      </Directory>

    </Directory>



    <Feature Id="ProductFeature" Title="WALL-E 桌面宠物" Level="1">

      <ComponentRef Id="MainExecutable" />

      <ComponentRef Id="DesktopShortcut" />

    </Feature>

  </Product>

</Wix>


